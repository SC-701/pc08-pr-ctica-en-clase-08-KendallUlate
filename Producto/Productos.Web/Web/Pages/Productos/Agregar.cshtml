@page
@model Web.Pages.Productos.AgregarModel

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow border-0 rounded-4">
                <div class="card-body p-4">

                    <div class="text-center mb-4">
                        <h2 class="fw-bold text-primary">Agregar producto</h2>
                        <p class="text-muted mb-0">Completa la información para registrar un nuevo producto</p>
                    </div>

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Producto.Nombre" class="form-label fw-semibold"></label>
                                <input asp-for="Producto.Nombre" class="form-control rounded-3" />
                                <span asp-validation-for="Producto.Nombre" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Producto.Precio" class="form-label fw-semibold"></label>
                                <input asp-for="Producto.Precio" class="form-control rounded-3" />
                                <span asp-validation-for="Producto.Precio" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Producto.Stock" class="form-label fw-semibold"></label>
                                <input asp-for="Producto.Stock" class="form-control rounded-3" />
                                <span asp-validation-for="Producto.Stock" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Producto.CodigoBarras" class="form-label fw-semibold"></label>
                                <input asp-for="Producto.CodigoBarras" class="form-control rounded-3" />
                                <span asp-validation-for="Producto.CodigoBarras" class="text-danger"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="Producto.Descripcion" class="form-label fw-semibold"></label>
                                <textarea asp-for="Producto.Descripcion" class="form-control rounded-3" rows="4"></textarea>
                                <span asp-validation-for="Producto.Descripcion" class="text-danger"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="Producto.IdSubCategoria" class="form-label fw-semibold"></label>
                                <input asp-for="Producto.IdSubCategoria" class="form-control rounded-3" />
                                <span asp-validation-for="Producto.IdSubCategoria" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-center gap-2 mt-4">
                            <a asp-page="./Index" class="btn btn-danger rounded-pill px-4">
                                Volver
                            </a>
                            <button type="submit" class="btn btn-success rounded-pill px-4">
                                Guardar producto
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}